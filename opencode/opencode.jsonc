{
  "$schema": "https://opencode.ai/config.json",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "agent": {
    "alice": {
      "temperature": 0.1,
      "description": "A companion to help explore and build your kingdom",
      "mode": "primary",
      "prompt": "{file:./agent.md}",
      "permission": {
        "*": "ask",
        "external_directory": {
          "~/.alice/**": "allow",
          "~/.koad-io/packages/**": "allow",
          "~/.ecoincore/packages/**": "allow"
        },
        "read": {
          "~/.alice/**": "allow",
          "~/.koad-io/packages/**": "allow",
          "~/.ecoincore/packages/**": "allow",
          "~/.agents": "allow",
          ".env": "allow",
          ".env.*": "allow",
          "*.env": "allow",
          ".sensitive": "deny",
          ".secrets": "deny"
        },
        "write": {
          "~/.sensitive/**": "deny",
          "~/.secrets/**": "deny",
          "~/.agents": "allow",
          "~/.alice/**": "allow"
        },
        "bash": {
          "~/.sensitive/**": "deny",
          "~/.secrets/**": "deny"
        },
        "glob": {
          "~/.sensitive/**": "deny",
          "~/.secrets/**": "deny"
        },
        "grep": {
          "~/.sensitive/**": "deny",
          "~/.secrets/**": "deny"
        },
        "skill": "allow",
        "task": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    }
  }
}
